# Port du serveur Express EJS (frontend)
PORT=3000

# URL de base du BACKEND API uniquement (Express + routes /payments, /orders, etc.).
# Ce n’est PAS l’URL du frontend : si tu mets le port du site EJS ici, tu obtiens du HTML à la place du JSON.
# Exemple courant : http://localhost:3001 ou http://localhost:3002 selon le .env du dépôt backend.
API_URL=http://localhost:3002

SESSION_SECRET=changez_moi_en_production
