<%- include('../partials/header', { title: title }) %>

<main class="container-fluid px-0 flex-grow-1" style="max-width: 640px">
  <div class="mb-4">
    <a href="/categories" class="text-decoration-none small text-muted"><i class="bi bi-arrow-left me-1"></i>Catégories</a>
    <h1 class="font-display customers-title mt-2 mb-1">Nouvelle catégorie</h1>
    <p class="customers-subtitle mb-0">Le nom est obligatoire</p>
  </div>

  <div class="customers-table-wrap p-4 p-md-5">
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger py-2 small"><%= error %></div>
    <% } %>

    <form method="post" action="/categories" novalidate>
      <div class="mb-3">
        <label class="form-label fw-semibold" for="name">Nom</label>
        <input
          class="form-control <%= fieldErrors.name ? 'is-invalid' : '' %>"
          id="name"
          name="name"
          type="text"
          value="<%= body.name || '' %>"
        />
        <% if (fieldErrors.name) { %><div class="invalid-feedback"><%= fieldErrors.name %></div><% } %>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold" for="description">Description</label>
        <textarea class="form-control" id="description" name="description" rows="3"><%= body.description || '' %></textarea>
      </div>

      <div class="mb-4">
        <label class="form-label fw-semibold" for="image_url">Image (URL)</label>
        <input
          class="form-control"
          id="image_url"
          name="image_url"
          type="text"
          autocomplete="off"
          placeholder="http://localhost:3000/images/categories/mon-image.png"
          value="<%= body.image_url || '' %>"
        />
        <div class="form-text small text-muted">
          Fichier dans <code>public/images/categories/</code> → URL
          <code>http://localhost:3000/images/categories/nomfichier.png</code> (pas le chemin <code>public/...</code>).
        </div>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-saveur">Créer</button>
        <a href="/categories" class="btn btn-outline-secondary">Annuler</a>
      </div>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
