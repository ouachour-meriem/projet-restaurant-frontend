<%- include('../partials/header', { title: title }) %>

<main class="container-fluid px-0 flex-grow-1" style="max-width: 640px">
  <div class="mb-4">
    <a href="/users" class="text-decoration-none small text-muted"><i class="bi bi-arrow-left me-1"></i>Utilisateurs</a>
    <h1 class="font-display customers-title mt-2 mb-1">Nouvel utilisateur</h1>
    <p class="customers-subtitle mb-0">E-mail et mot de passe obligatoires</p>
  </div>

  <div class="customers-table-wrap p-4 p-md-5">
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger py-2 small"><%= error %></div>
    <% } %>

    <form method="post" action="/users" novalidate>
      <div class="mb-3">
        <label class="form-label fw-semibold" for="name">Nom complet</label>
        <input
          class="form-control <%= fieldErrors.name ? 'is-invalid' : '' %>"
          id="name"
          name="name"
          type="text"
          value="<%= body.name || '' %>"
        />
        <% if (fieldErrors.name) { %><div class="invalid-feedback"><%= fieldErrors.name %></div><% } %>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold" for="email">E-mail</label>
        <input
          class="form-control <%= fieldErrors.email ? 'is-invalid' : '' %>"
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          value="<%= body.email || '' %>"
        />
        <% if (fieldErrors.email) { %><div class="invalid-feedback"><%= fieldErrors.email %></div><% } %>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold" for="password">Mot de passe</label>
        <input
          class="form-control <%= fieldErrors.password ? 'is-invalid' : '' %>"
          id="password"
          name="password"
          type="password"
          autocomplete="new-password"
        />
        <% if (fieldErrors.password) { %><div class="invalid-feedback"><%= fieldErrors.password %></div><% } %>
        <div class="form-text">Au moins 6 caractères (règle API).</div>
      </div>

      <div class="mb-4">
        <label class="form-label fw-semibold" for="role_id">Rôle</label>
        <select class="form-select <%= fieldErrors.role_id ? 'is-invalid' : '' %>" id="role_id" name="role_id">
          <option value="">— Choisir —</option>
          <% (roles || []).forEach(function (role) { %>
          <option value="<%= role.id %>" <%= String(body.role_id) === String(role.id) ? 'selected' : '' %>>
            <%= role.name %>
          </option>
          <% }); %>
        </select>
        <% if (fieldErrors.role_id) { %><div class="invalid-feedback"><%= fieldErrors.role_id %></div><% } %>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-saveur">Créer</button>
        <a href="/users" class="btn btn-outline-secondary">Annuler</a>
      </div>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
