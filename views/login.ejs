<%- include('partials/header', { title: 'Connexion' }) %>

<main class="container py-4 flex-grow-1" style="max-width: 420px">
  <h1 class="font-display h3 mb-3">Connexion</h1>
  <p class="text-muted small">
    Connexion via l’API <code>/auth/login</code> (JWT stocké en session) pour accéder aux pages Clients et Commandes.
  </p>

  <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <form method="post" action="/login" autocomplete="on">
    <input type="hidden" name="redirect" value="<%= typeof redirect !== 'undefined' ? redirect : '/customers' %>" />
    <div class="mb-3">
      <label class="form-label" for="email">E-mail</label>
      <input
        class="form-control"
        id="email"
        name="email"
        type="email"
        required
        value="<%= typeof email !== 'undefined' ? email : '' %>"
      />
    </div>
    <div class="mb-3">
      <label class="form-label" for="password">Mot de passe</label>
      <input class="form-control" id="password" name="password" type="password" required />
    </div>
    <button class="btn btn-saveur w-100" type="submit">Se connecter</button>
  </form>
</main>

<%- include('partials/footer') %>
