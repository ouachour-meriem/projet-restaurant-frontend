<%- include('../partials/header', { title: title }) %>

<main class="container-fluid px-0 flex-grow-1">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
      <h1 class="font-display customers-title mb-1">Produits</h1>
      <p class="customers-subtitle mb-0">Catalogue, prix et stock par catégorie</p>
    </div>
    <a class="btn btn-saveur customers-add-btn" href="/products/new">
      <i class="bi bi-plus-lg me-1"></i>
      Ajouter produit
    </a>
  </div>

  <div class="customers-table-wrap">
    <% if (!products || products.length === 0) { %>
    <div class="customers-empty">Aucun produit trouvé.</div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table align-middle mb-0 customers-table dash-recent-table">
        <thead>
          <tr>
            <th style="width: 72px">Image</th>
            <th>Nom</th>
            <th>Catégorie</th>
            <th class="text-end">Prix</th>
            <th class="text-end">Stock</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach(function (p) { %>
          <% const catName = (p.category && p.category.name) ? p.category.name : (p.category_name || ('#' + (p.category_id || ''))); %>
          <tr>
            <td>
              <% if (p.image_url) { %>
              <img
                src="<%= p.image_url %>"
                alt=""
                class="product-thumb"
                width="44"
                height="44"
                loading="lazy"
                onerror="this.onerror=null;this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2244%22 height=%2244%22%3E%3Crect fill=%22%23f2ebe5%22 width=%2244%22 height=%2244%22 rx=%228%22/%3E%3C/svg%3E';"
              />
              <% } else { %>
              <div class="product-thumb-placeholder"><i class="bi bi-box-seam text-muted"></i></div>
              <% } %>
            </td>
            <td>
              <div class="customer-name"><%= p.name || ('#' + p.id) %></div>
              <% if (p.description) { %>
              <div class="small text-muted text-truncate" style="max-width: 280px"><%= p.description %></div>
              <% } %>
            </td>
            <td>
              <span class="badge rounded-pill text-bg-light border"><%= catName %></span>
            </td>
            <td class="text-end customer-metric">
              <% if (p.price != null && Number.isFinite(Number(p.price))) { %>
              <%= Number(p.price).toLocaleString("en-US", { style: "currency", currency: "USD" }) %>
              <% } else { %>
              —
              <% } %>
            </td>
            <td class="text-end customer-metric"><%= p.stock != null ? p.stock : '—' %></td>
            <td class="text-end text-nowrap">
              <a class="btn btn-sm btn-outline-secondary" href="/products/<%= p.id %>/edit" title="Modifier">
                <i class="bi bi-pencil"></i>
              </a>
              <form
                class="d-inline"
                method="post"
                action="/products/<%= p.id %>/delete"
                onsubmit="return confirm('Supprimer ce produit ?');"
              >
                <button class="btn btn-sm btn-outline-danger" type="submit" title="Supprimer">
                  <i class="bi bi-trash3"></i>
                </button>
              </form>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <% if (pagination && pagination.totalPages > 1) { %>
  <nav class="mt-3" aria-label="Pagination">
    <ul class="pagination pagination-sm">
      <% if (pagination.page > 1) { %>
      <li class="page-item">
        <a class="page-link" href="?page=<%= pagination.page - 1 %>&limit=<%= pagination.limit %>">Précédent</a>
      </li>
      <% } %>
      <li class="page-item disabled">
        <span class="page-link"><%= pagination.page %> / <%= pagination.totalPages %></span>
      </li>
      <% if (pagination.page < pagination.totalPages) { %>
      <li class="page-item">
        <a class="page-link" href="?page=<%= pagination.page + 1 %>&limit=<%= pagination.limit %>">Suivant</a>
      </li>
      <% } %>
    </ul>
  </nav>
  <% } %>
</main>

<%- include('../partials/footer') %>
