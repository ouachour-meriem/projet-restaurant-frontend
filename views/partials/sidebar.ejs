<% const path = typeof currentPath !== "undefined" ? currentPath : ""; %>
<% const navActive = (p) => (p === "/" ? path === "/" || path === "" : path === p || path.startsWith(p + "/")); %>
<% const dashActive = path === "/" || path === ""; %>
<aside class="app-sidebar d-flex flex-column">
  <div class="sidebar-brand px-3 pt-4 pb-3">
    <div class="sidebar-logo font-display">Saveur</div>
    <div class="sidebar-sub">Restaurant Manager</div>
  </div>
  <nav class="sidebar-nav flex-grow-1 px-2 pb-3" aria-label="Navigation principale">
    <a href="/" class="sidebar-link <%= dashActive ? 'active' : '' %>">
      <i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span>
    </a>
    <a href="/products" class="sidebar-link <%= navActive('/products') ? 'active' : '' %>">
      <i class="bi bi-box-seam"></i><span>Products</span>
    </a>
    <a href="/categories" class="sidebar-link <%= navActive('/categories') ? 'active' : '' %>">
      <i class="bi bi-tags"></i><span>Categories</span>
    </a>
    <% if (typeof isAdmin !== "undefined" && isAdmin) { %>
    <a href="/customers" class="sidebar-link <%= navActive('/customers') ? 'active' : '' %>">
      <i class="bi bi-people"></i><span>Customers</span>
    </a>
    <a href="/users" class="sidebar-link <%= navActive('/users') ? 'active' : '' %>">
      <i class="bi bi-person-badge"></i><span>Users</span>
    </a>
    <a href="/roles" class="sidebar-link <%= navActive('/roles') ? 'active' : '' %>">
      <i class="bi bi-shield-lock"></i><span>Roles</span>
    </a>
    <% } %>
    <a href="/orders" class="sidebar-link <%= navActive('/orders') ? 'active' : '' %>">
      <i class="bi bi-cart3"></i><span>Orders</span>
    </a>
    <% if (typeof isAdmin !== "undefined" && isAdmin) { %>
    <a href="/order-items" class="sidebar-link <%= navActive('/order-items') ? 'active' : '' %>">
      <i class="bi bi-list-task"></i><span>Order Items</span>
    </a>
    <a href="/payments" class="sidebar-link <%= navActive('/payments') ? 'active' : '' %>">
      <i class="bi bi-credit-card"></i><span>Payments</span>
    </a>
    <% } %>
  </nav>
  <div class="sidebar-footer px-3 pb-4">
    <a href="/logout" class="sidebar-link sidebar-link-logout"><i class="bi bi-box-arrow-right"></i><span>Logout</span></a>
  </div>
</aside>
