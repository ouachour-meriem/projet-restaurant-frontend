<%- include('../partials/header', { title: title }) %>

<main class="container-fluid px-0 flex-grow-1 payments-page">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
      <h1 class="font-display payments-title mb-1">Payments</h1>
      <p class="payments-subtitle mb-0">Monitor transactions and financial activity</p>
    </div>
    <a class="btn btn-saveur payments-add-btn" href="/payments/new"><i class="bi bi-plus-lg me-1"></i> New Payment</a>
  </div>

  <div class="row g-3 mb-4 payments-kpi-row">
    <div class="col-md-4">
      <div class="payments-kpi-card d-flex align-items-center gap-3">
        <div class="payments-kpi-icon payments-kpi-icon--revenue">
          <i class="bi bi-credit-card-2-front"></i>
        </div>
        <div>
          <div class="payments-kpi-label">Total Revenue</div>
          <div class="payments-kpi-value">$<%= Number(stats.totalRevenue || 0).toFixed(2) %></div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="payments-kpi-card d-flex align-items-center gap-3">
        <div class="payments-kpi-icon payments-kpi-icon--pending">
          <i class="bi bi-calendar-event"></i>
        </div>
        <div>
          <div class="payments-kpi-label">Pending Payments</div>
          <div class="payments-kpi-value"><%= stats.pendingCount != null ? stats.pendingCount : 0 %></div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="payments-kpi-card d-flex align-items-center gap-3">
        <div class="payments-kpi-icon payments-kpi-icon--count">
          <i class="bi bi-credit-card"></i>
        </div>
        <div>
          <div class="payments-kpi-label">Total Transactions</div>
          <div class="payments-kpi-value"><%= stats.totalTransactions != null ? stats.totalTransactions : 0 %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="payments-table-wrap">
    <% if (!payments || payments.length === 0) { %>
    <div class="payments-empty">No payments found.</div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table align-middle mb-0 payments-table">
        <thead>
          <tr>
            <th>TRANSACTION ID</th>
            <th>ORDER #</th>
            <th>CUSTOMER</th>
            <th>AMOUNT</th>
            <th>METHOD</th>
            <th>STATUS</th>
            <th>DATE &amp; TIME</th>
            <th class="text-end">ACTIONS</th>
          </tr>
        </thead>
        <tbody>
          <% payments.forEach(function (p) { %>
          <% const oid = p.order_id != null ? p.order_id : (p.order && p.order.id); %>
          <% const cust = (p.order && p.order.customer) || p.customer; %>
          <% const first = cust && cust.first_name ? String(cust.first_name) : ''; %>
          <% const last = cust && cust.last_name ? String(cust.last_name) : ''; %>
          <% const customerName = `${first} ${last}`.trim() || '—'; %>
          <% const txnId = 'TXN-' + String(p.id || '').padStart(7, '0'); %>
          <% const when = p.payment_date ? new Date(p.payment_date) : null; %>
          <tr>
            <td class="payments-txn-id"><%= txnId %></td>
            <td>
              <span class="payments-order-ref">#ORD-<%= oid != null ? oid : '—' %></span>
            </td>
            <td class="payments-customer-name"><%= customerName %></td>
            <td class="payments-amount">$<%= p.amount != null ? Number(p.amount).toFixed(2) : '—' %></td>
            <td class="text-muted"><%= p.payment_method || '—' %></td>
            <td><%- include('../partials/statusBadge', { status: p.status }) %></td>
            <td class="payments-datetime">
              <% if (when && !Number.isNaN(when.getTime())) { %>
              <div><%= when.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' }) %></div>
              <div class="payments-time"><%= when.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) %></div>
              <% } else { %>
              —
              <% } %>
            </td>
            <td class="text-end text-nowrap">
              <a class="btn btn-sm btn-outline-secondary payments-action-btn" href="/payments/<%= p.id %>/edit" title="Edit">
                <i class="bi bi-pencil"></i>
              </a>
              <form
                class="d-inline"
                method="post"
                action="/payments/<%= p.id %>/delete"
                onsubmit="return confirm('Delete this payment?');"
              >
                <button class="btn btn-sm btn-outline-danger payments-action-btn" type="submit" title="Delete">
                  <i class="bi bi-trash3"></i>
                </button>
              </form>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <% if (pagination && pagination.totalPages > 1) { %>
  <nav class="mt-3" aria-label="Pagination">
    <ul class="pagination pagination-sm">
      <% if (pagination.page > 1) { %>
      <li class="page-item">
        <a class="page-link" href="?page=<%= pagination.page - 1 %>&limit=<%= pagination.limit %>">Previous</a>
      </li>
      <% } %>
      <li class="page-item disabled">
        <span class="page-link"><%= pagination.page %> / <%= pagination.totalPages %></span>
      </li>
      <% if (pagination.page < pagination.totalPages) { %>
      <li class="page-item">
        <a class="page-link" href="?page=<%= pagination.page + 1 %>&limit=<%= pagination.limit %>">Next</a>
      </li>
      <% } %>
    </ul>
  </nav>
  <% } %>
</main>

<%- include('../partials/footer') %>
