<%- include('../partials/header', { title: title }) %>

<main class="container-fluid px-0 flex-grow-1">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
      <h1 class="font-display h2 mb-1">Commandes</h1>
      <p class="text-muted mb-0">Liste des commandes et lien avec le client.</p>
    </div>
    <a class="btn btn-saveur" href="/orders/new">+ Nouvelle commande</a>
  </div>

  <form class="row g-2 mb-4 align-items-end" method="get" action="/orders">
    <div class="col-md-3">
      <label class="form-label small" for="customer_name">Client (nom)</label>
      <input
        class="form-control"
        id="customer_name"
        name="customer_name"
        type="text"
        placeholder="Nom du client"
        value="<%= query && query.customer_name ? query.customer_name : '' %>"
      />
    </div>
    <div class="col-md-3">
      <label class="form-label small" for="status">Statut</label>
      <input
        class="form-control"
        id="status"
        name="status"
        type="text"
        placeholder="pending, completed…"
        value="<%= query && query.status ? query.status : '' %>"
      />
    </div>
    <div class="col-md-2">
      <label class="form-label small" for="limit">Par page</label>
      <select class="form-select" id="limit" name="limit">
        <% const lim = (query && query.limit) || 10; %>
        <% [10, 25, 50].forEach(function (n) { %>
        <option value="<%= n %>" <%= String(lim) === String(n) ? 'selected' : '' %>><%= n %></option>
        <% }); %>
      </select>
    </div>
    <div class="col-md-2">
      <button class="btn btn-outline-secondary w-100" type="submit">Filtrer</button>
    </div>
  </form>

  <% if (!orders || orders.length === 0) { %>
  <p class="text-muted">Aucune commande trouvée.</p>
  <% } else { %>
  <div class="table-responsive shadow-sm rounded bg-white">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>#</th>
          <th>Client</th>
          <th>Items</th>
          <th>Date</th>
          <th>Heure</th>
          <th>Montant</th>
          <th>Statut</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach(function (o) { %>
        <% const orderDate = o.order_date ? new Date(o.order_date) : null; %>
        <% const itemsText = Array.isArray(o.items)
          ? o.items.join(', ')
          : (o.items || o.item || o.description || (Array.isArray(o.order_items) && o.order_items.length
              ? o.order_items.map(function (it) { return it.name || it.product_name || ('#' + (it.id || '')); }).join(', ')
              : '—')); %>
        <tr>
          <td><%= o.id %></td>
          <td>
            <% if (o.customer) { %>
            <%= o.customer.first_name %> <%= o.customer.last_name %>
            <% } else { %>
            <span class="text-muted">—</span>
            <% } %>
          </td>
          <td class="small text-muted"><%= itemsText %></td>
          <td class="small">
            <% if (orderDate && !Number.isNaN(orderDate.getTime())) { %>
            <%= orderDate.toLocaleDateString('fr-FR') %>
            <% } else { %>
            —
            <% } %>
          </td>
          <td class="small">
            <% if (orderDate && !Number.isNaN(orderDate.getTime())) { %>
            <%= orderDate.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' }) %>
            <% } else { %>
            —
            <% } %>
          </td>
          <td>
            <% if (o.total_amount != null) { %><%= Number(o.total_amount).toLocaleString("en-US", { style: "currency", currency: "USD" }) %><% } %>
          </td>
          <td><%- include('../partials/statusBadge', { status: o.status }) %></td>
          <td class="text-end text-nowrap">
            <a class="btn btn-sm btn-outline-primary" href="/orders/<%= o.id %>/edit">Modifier</a>
            <form
              class="d-inline"
              method="post"
              action="/orders/<%= o.id %>/delete"
              onsubmit="return confirm('Supprimer cette commande ?');"
            >
              <button class="btn btn-sm btn-outline-danger" type="submit">Supprimer</button>
            </form>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <% if (pagination) { %>
  <nav class="mt-3" aria-label="Pagination">
    <ul class="pagination">
      <% if (pagination.page > 1) { %>
      <li class="page-item">
        <a
          class="page-link"
          href="?page=<%= pagination.page - 1 %>&limit=<%= pagination.limit %><%= query.customer_name ? '&customer_name=' + encodeURIComponent(query.customer_name) : '' %><%= query.status ? '&status=' + encodeURIComponent(query.status) : '' %>"
          >Précédent</a
        >
      </li>
      <% } %>
      <li class="page-item disabled">
        <span class="page-link">Page <%= pagination.page %> / <%= pagination.totalPages || 1 %></span>
      </li>
      <% if (pagination.page < (pagination.totalPages || 1)) { %>
      <li class="page-item">
        <a
          class="page-link"
          href="?page=<%= pagination.page + 1 %>&limit=<%= pagination.limit %><%= query.customer_name ? '&customer_name=' + encodeURIComponent(query.customer_name) : '' %><%= query.status ? '&status=' + encodeURIComponent(query.status) : '' %>"
          >Suivant</a
        >
      </li>
      <% } %>
    </ul>
  </nav>
  <% } %> <% } %>
</main>

<%- include('../partials/footer') %>
