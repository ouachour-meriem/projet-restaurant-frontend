<%- include('../partials/header', { title: title }) %>

<main class="container-fluid px-0 flex-grow-1" style="max-width: 640px">
  <h1 class="font-display h3 mb-3">Modifier la commande</h1>

  <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <% const o = order || {}; const b = body && Object.keys(body).length ? body : {}; %>
  <form method="post" action="/orders/<%= o.id %>/update" novalidate>
    <div class="mb-3">
      <label class="form-label" for="customer_id">Client <span class="text-danger">*</span></label>
      <% if (customers && customers.length) { %>
      <select
        class="form-select <%= fieldErrors.customer_id ? 'is-invalid' : '' %>"
        id="customer_id"
        name="customer_id"
        required
      >
        <option value="">— Choisir —</option>
        <% customers.forEach(function (c) { %>
        <option
          value="<%= c.id %>"
          <%= String(b.customer_id != null ? b.customer_id : o.customer_id) === String(c.id) ? 'selected' : '' %>
        >
          <%= c.id %> — <%= c.first_name %> <%= c.last_name %>
        </option>
        <% }); %>
      </select>
      <% } else { %>
      <input
        class="form-control <%= fieldErrors.customer_id ? 'is-invalid' : '' %>"
        id="customer_id"
        name="customer_id"
        type="number"
        min="1"
        required
        value="<%= b.customer_id != null ? b.customer_id : o.customer_id || '' %>"
      />
      <% } %>
      <% if (fieldErrors.customer_id) { %>
      <div class="invalid-feedback d-block"><%= fieldErrors.customer_id %></div>
      <% } %>
    </div>

    <div class="mb-3">
      <label class="form-label" for="order_date">Date de commande <span class="text-danger">*</span></label>
      <input
        class="form-control <%= fieldErrors.order_date ? 'is-invalid' : '' %>"
        id="order_date"
        name="order_date"
        type="datetime-local"
        required
        value="<%= b.order_date ? b.order_date : (typeof orderDateLocal !== 'undefined' ? orderDateLocal : '') %>"
      />
      <% if (fieldErrors.order_date) { %>
      <div class="invalid-feedback"><%= fieldErrors.order_date %></div>
      <% } %>
    </div>

    <div class="mb-3">
      <label class="form-label" for="status">Statut <span class="text-danger">*</span></label>
      <% const st = b.status || o.status || 'pending'; %>
      <select
        class="form-select <%= fieldErrors.status ? 'is-invalid' : '' %>"
        id="status"
        name="status"
        required
      >
        <option value="pending" <%= st === 'pending' ? 'selected' : '' %>>pending</option>
        <option value="processing" <%= st === 'processing' ? 'selected' : '' %>>processing</option>
        <option value="completed" <%= st === 'completed' ? 'selected' : '' %>>completed</option>
        <option value="cancelled" <%= st === 'cancelled' ? 'selected' : '' %>>cancelled</option>
      </select>
      <% if (fieldErrors.status) { %>
      <div class="invalid-feedback d-block"><%= fieldErrors.status %></div>
      <% } %>
    </div>

    <div class="mb-3">
      <label class="form-label" for="total_amount">Montant total (USD) <span class="text-danger">*</span></label>
      <input
        class="form-control <%= fieldErrors.total_amount ? 'is-invalid' : '' %>"
        id="total_amount"
        name="total_amount"
        type="text"
        inputmode="decimal"
        required
        value="<%= b.total_amount != null ? b.total_amount : (o.total_amount != null ? o.total_amount : '') %>"
      />
      <% if (fieldErrors.total_amount) { %>
      <div class="invalid-feedback"><%= fieldErrors.total_amount %></div>
      <% } %>
    </div>

    <div class="d-flex gap-2">
      <button class="btn btn-saveur" type="submit">Enregistrer</button>
      <a class="btn btn-outline-secondary" href="/orders">Annuler</a>
    </div>
  </form>
</main>

<%- include('../partials/footer') %>
