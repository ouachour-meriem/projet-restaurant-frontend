<%- include('../partials/header', { title: title }) %>

<main class="container-fluid px-0 flex-grow-1">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
      <h1 class="font-display customers-title mb-1">Clients</h1>
      <p class="customers-subtitle mb-0">Gérez vos relations clients et leurs informations</p>
    </div>
    <a class="btn btn-saveur customers-add-btn" href="/customers/new">
      <i class="bi bi-plus-lg me-1"></i>
      Ajouter client
    </a>
  </div>

  <div class="customers-table-wrap">
    <% if (!customers || customers.length === 0) { %>
    <div class="customers-empty">Aucun client trouvé.</div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table align-middle mb-0 customers-table">
        <thead>
          <tr>
            <th>Client</th>
            <th>Contact</th>
            <th>Adresse</th>
            <th class="text-end">Commandes</th>
            <th class="text-end">Total dépensé</th>
            <th>Statut</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% customers.forEach(function (c) { %>
          <% const fullName = `${c.first_name || ''} ${c.last_name || ''}`.trim(); %>
          <% const initials = ((c.first_name || '').charAt(0) + (c.last_name || '').charAt(0)).toUpperCase() || 'CU'; %>
          <% const fakeOrders = (c.id * 7) % 65 + 8; %>
          <% const fakeSpent = fakeOrders * 22.5; %>
          <tr>
            <td>
              <div class="d-flex align-items-center gap-3">
                <div class="customer-avatar"><%= initials %></div>
                <div>
                  <div class="customer-name"><%= fullName || ('Client #' + c.id) %></div>
                </div>
              </div>
            </td>
            <td>
              <div class="customer-contact-line">
                <i class="bi bi-envelope"></i>
                <span><%= c.email || 'e-mail non défini' %></span>
              </div>
              <div class="customer-contact-line">
                <i class="bi bi-telephone"></i>
                <span><%= c.phone || 'téléphone non défini' %></span>
              </div>
            </td>
            <td class="customer-location">
              <i class="bi bi-geo-alt"></i>
              <span><%= c.address || c.location || 'Adresse non renseignée' %></span>
            </td>
            <td class="text-end customer-metric"><%= fakeOrders %></td>
            <td class="text-end customer-metric">$<%= fakeSpent.toFixed(0) %></td>
            <td>
              <% const st = String(c.status || 'active').toLowerCase(); %>
              <span class="badge <%= st === 'inactive' ? 'text-bg-secondary' : 'text-bg-success' %> rounded-pill">
                <%= st === 'inactive' ? 'Inactif' : 'Actif' %>
              </span>
            </td>
            <td class="text-end text-nowrap">
              <a class="btn btn-sm btn-outline-secondary" href="/customers/<%= c.id %>/edit">
                <i class="bi bi-pencil"></i>
              </a>
              <form
                class="d-inline"
                method="post"
                action="/customers/<%= c.id %>/delete"
                onsubmit="return confirm('Supprimer ce client ?');"
              >
                <button class="btn btn-sm btn-outline-danger" type="submit">
                  <i class="bi bi-trash3"></i>
                </button>
              </form>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <% if (pagination && pagination.totalPages > 1) { %>
  <nav class="mt-3" aria-label="Pagination">
    <ul class="pagination pagination-sm">
      <% if (pagination.page > 1) { %>
      <li class="page-item">
        <a
          class="page-link"
          href="?page=<%= pagination.page - 1 %>&limit=<%= pagination.limit %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"
          >Précédent</a
        >
      </li>
      <% } %>
      <li class="page-item disabled">
        <span class="page-link"><%= pagination.page %> / <%= pagination.totalPages %></span>
      </li>
      <% if (pagination.page < pagination.totalPages) { %>
      <li class="page-item">
        <a
          class="page-link"
          href="?page=<%= pagination.page + 1 %>&limit=<%= pagination.limit %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"
          >Suivant</a
        >
      </li>
      <% } %>
    </ul>
  </nav>
  <% } %>
</main>

<%- include('../partials/footer') %>
